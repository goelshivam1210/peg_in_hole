<mujoco model="peg_in_hole_step5">

  <include file="robotiq_2f85/2f85_free.xml" />

  <asset>
    <mesh name="peg" file="peg.stl" scale="0.001 0.001 0.001" />
    <mesh name="cuboid" file="cuboid.stl" scale="0.001 0.001 0.001" />
  </asset>

  <worldbody>
    <light pos="0 0 1" diffuse="1 1 1" />
    <geom type="plane" size="0.5 0.5 0.01" rgba="0.3 0.3 0.3 1" />

    <body name="mocap" mocap="true" pos="0 0 0.2">
      <geom type="box" size="0.02 0.02 0.02" rgba="1 0 0 0.3" contype="0" conaffinity="0" />
    </body>

    <body name="peg" pos="0.15 0 0.015" euler="0 1.5708 0">
      <freejoint/>
      <geom type="mesh" mesh="peg" rgba="0.2 0.6 0.9 1" />
    </body>

    <body name="cuboid" pos="0.35 0 0.05">
      <!-- Visual only (no collision) -->
      <geom type="mesh" mesh="cuboid" rgba="0.9 0.4 0.2 1"
            contype="0" conaffinity="0" />

      <!-- Collision boxes forming the hole walls + floor -->
      <geom name="hole_floor"   type="box" size="0.050 0.050 0.015"
            pos="0 0 -0.035" rgba="0.9 0.4 0.2 1" />
      <geom name="hole_wall_xn" type="box" size="0.015 0.050 0.035"
            pos="-0.035 0 0.015" rgba="0.9 0.4 0.2 1" />
      <geom name="hole_wall_xp" type="box" size="0.015 0.050 0.035"
            pos="0.035 0 0.015" rgba="0.9 0.4 0.2 1" />
      <geom name="hole_wall_yn" type="box" size="0.020 0.015 0.035"
            pos="0 -0.035 0.015" rgba="0.9 0.4 0.2 1" />
      <geom name="hole_wall_yp" type="box" size="0.020 0.015 0.035"
            pos="0 0.035 0.015" rgba="0.9 0.4 0.2 1" />
    </body>
  </worldbody>

  <equality>
    <weld body1="mocap" body2="base_mount" solref="0.01 1" solimp="0.9 0.95 0.001"/>
  </equality>

</mujoco>